# fs_read_secrets.rules

rule block-ssh-key-access {
  MESSAGE "Blocked access to private SSH keys to prevent potential credential theft."
  IF path GLOB "**/.ssh/id_*"
  OR path GLOB "**/.ssh/*.pem"
  severity error
  priority 100
  DENY read
}

rule block-env-file-access {
  MESSAGE "Blocked direct reading of environment files which typically contain sensitive API keys and secrets."
  IF path GLOB "**/.env*"
  AND path NOT GLOB "**/.env.example"
  AND path NOT GLOB "**/.env.template"
  severity warning
  priority 95
  ASK read
  PROMPT "The agent is attempting to read an environment file. This may expose sensitive secrets. Allow?"
}

rule block-aws-credentials-access {
  MESSAGE "Blocked access to AWS credentials files."
  IF path GLOB "**/.aws/credentials"
  OR path GLOB "**/.aws/config"
  severity error
  priority 100
  DENY read
}

rule block-kube-config-access {
  MESSAGE "Blocked access to Kubernetes configuration files."
  IF path GLOB "**/.kube/config"
  severity error
  priority 100
  DENY read
}

rule block-browser-profiles {
  MESSAGE "Blocked access to browser profile directories which contain cookies and saved passwords."
  IF path CONTAINS "/Library/Application Support/Google/Chrome/"
  OR path CONTAINS "/.config/google-chrome/"
  OR path CONTAINS "/AppData/Local/Google/Chrome/"
  severity error
  priority 100
  DENY read
}
